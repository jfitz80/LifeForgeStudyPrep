generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model NewsSource {
  id             String        @id @default(cuid())
  name           String
  slug           String        @unique
  type           String
  feedUrl        String
  homepageUrl    String?
  isActive       Boolean       @default(true)
  requiresReview Boolean       @default(true)
  priority       Int           @default(0)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  articles       NewsArticle[]

  @@index([isActive, priority])
}

model NewsArticle {
  id               String     @id @default(cuid())
  sourceId         String
  source           NewsSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  title            String
  slug             String     @unique
  canonicalUrl     String     @unique
  author           String?
  publishedAt      DateTime
  excerpt          String?
  imageUrl         String?
  summary          String
  whyItMatters     String
  whoItAffects     String
  llqpAngle        String?
  status           String     @default("PENDING")
  isFeatured       Boolean    @default(false)
  relevanceScore   Int        @default(0)
  tagsJson         String?
  attributionLabel String
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  @@index([status, publishedAt(sort: Desc)])
  @@index([isFeatured, publishedAt(sort: Desc)])
}

model IngestionJob {
  id            String   @id @default(cuid())
  startedAt     DateTime @default(now())
  finishedAt    DateTime?
  status        String?
  itemsFetched  Int      @default(0)
  itemsAccepted Int      @default(0)
  itemsCreated  Int      @default(0)
  itemsRejected Int      @default(0)
  failedItems   Int      @default(0)
  errorMessage  String?
  detailsJson   String?
}
